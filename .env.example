# Lark App credentials — create an internal app at https://open.larksuite.com/
LARK_APP_ID=cli_xxxxxxxxxxxx
LARK_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Base URL (default: Lark global; use https://open.feishu.cn/open-apis for China)
LARK_BASE_URL=https://open.larksuite.com/open-apis

# HTTP server port (only used with --mode http)
PORT=3000

# Rate limit: max requests per second (default: 50)
LARK_RATE_LIMIT=50
